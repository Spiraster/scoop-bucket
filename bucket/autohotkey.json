{
    "version": "2.0.26",
    "description": "Macro and automation scripting utility",
    "homepage": "https://www.autohotkey.com/",
    "license": "GPL-2.0-or-later",
    "url": "https://github.com/AutoHotkey/AutoHotkey/releases/download/v2.0.26/AutoHotkey_2.0.26.zip",
    "hash": "43522aa3122a57784ac5db30abf85c2244475c36acd7796e2c993355f9e926ae",
    "extract_to": "temp",
    "pre_install": [
        "'AutoHotkey64.exe', 'UX\\WindowSpy.ahk' | % {",
        "   Move-Item \"$dir\\temp\\$_\" \"$dir\"",
        "}",
        "New-Item -Path \"$dir\\inc\" -ItemType Directory | Out-Null",
        "Move-Item \"$dir\\temp\\UX\\inc\\spy.ico\" \"$dir\\inc\"",
        "Remove-Item \"$dir\\temp\" -Recurse"
    ],
    "post_install": [
        "$dirPath = \"$dir\".Replace('\\', '\\\\')",
        "Get-ChildItem \"$bucketsdir\\$bucket\\scripts\\$app\\*.reg\" | ForEach-Object {",
        "    $content = (Get-Content \"$_\").Replace('$dir', $dirPath)",
        "    if ($global) {",
        "        $content = $content.Replace('HKEY_CURRENT_USER', 'HKEY_LOCAL_MACHINE')",
        "    }",
        "    Set-Content \"$dir\\$($_.Name)\" $content -Encoding utf8",
        "}",
        "reg import \"$dir\\install-associations.reg\" | Out-Null"
    ],
    "bin": [
        [
            "AutoHotkey64.exe",
            "autohotkey"
        ]
    ],
    "shortcuts": [
        [
            "WindowSpy.ahk",
            "Window Spy",
            "",
            "inc\\spy.ico"
        ]
    ],
    "pre_uninstall": [
        "if ($cmd -eq 'uninstall') {",
        "   reg import \"$dir\\uninstall-associations.reg\" | Out-Null",
        "}"
    ],
    "checkver": {
        "github": "https://github.com/AutoHotkey/AutoHotkey"
    },
    "autoupdate": {
        "url": "https://github.com/AutoHotkey/AutoHotkey/releases/download/v$version/AutoHotkey_$version.zip",
        "hash": {
            "url": "https://github.com/AutoHotkey/AutoHotkey/releases/tag/v$version",
            "regex": "$sha256</code>[\\s]+AutoHotkey_$version\\.zip"
        }
    }
}
